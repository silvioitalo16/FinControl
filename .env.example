# ============================================================
#  FinControl — Variáveis de Ambiente
#
#  Este arquivo é um modelo. Copie os blocos para os arquivos corretos:
#    Frontend → frontend/.env.local
#    Backend  → backend/.env.local
#  NUNCA commite os arquivos .env.local ou .env.
# ============================================================

# ── frontend/.env.local ───────────────────────────────────────
# Chaves públicas — aparecem no browser, não são segredos
VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...sua_anon_key...
VITE_API_URL=http://localhost:3001

# ── backend/.env.local ────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
LOG_LEVEL=info

# Supabase service_role — acesso total ao banco, NUNCA exponha no frontend
# Encontre em: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...sua_service_role_key...

# Prisma (acesso direto ao PostgreSQL)
# Encontre em: Supabase Dashboard → Project Settings → Database → Connection string
# DATABASE_URL  → Transaction pooler (porta 6543) — para queries do backend
# DIRECT_URL    → Direct connection (porta 5432)  — para prisma db pull/push
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
