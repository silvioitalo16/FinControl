# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=http

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL do frontend (sem barra no final)
CORS_ORIGIN=http://localhost:5173

# URL pública do frontend — usada nos links dos emails (ex: botão "Abrir FinControl")
APP_URL=http://localhost:5173

# ── Supabase ──────────────────────────────────────────────────────────────────
# Encontre em: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>

# ── Resend (email transacional) ───────────────────────────────────────────────
# Obtenha em: https://resend.com → API Keys → Create API Key
# Permissão necessária: "Sending access"
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Remetente dos emails — formato: "Nome <email>"
# Em dev pode usar o sandbox: "FinControl <onboarding@resend.dev>"
# Em prod use um domínio verificado no Resend: "FinControl <noreply@seudominio.com>"
EMAIL_FROM=FinControl <onboarding@resend.dev>

# ── Cloudflare Turnstile (CAPTCHA) ────────────────────────────────────────
# Obtenha em: https://dash.cloudflare.com → Turnstile → Add site
# Em dev pode deixar vazio (bypass automático)
# Em prod: chave secreta do Turnstile
TURNSTILE_SECRET_KEY=

# ── Prisma (opcional) ─────────────────────────────────────────────────────────
# Encontre em: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.<ref>:<senha>@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:<senha>@db.<ref>.supabase.co:5432/postgres
